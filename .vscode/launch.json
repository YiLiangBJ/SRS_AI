{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            // "console": "integratedTerminal",
            // "justMyCode": true
        },
        {
            "name": "Python: train.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Model_AIIC_refactor/train.py",
            "cwd": "${workspaceFolder}/Model_AIIC_refactor",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--experiment",
                "your_experiment_name",
                "--batch_size",
                "32",
                "--num_batches",
                "100",
                "--device",
                "auto",
                "--save_dir",
                "./experiments_refactored",
                "--no-amp",
                "--no-compile",
                "--eval_snr_range",
                "30:-3:0",
                "--eval_tdl",
                "A-30,B-100,C-300",
                "--eval_num_batches",
                "100",
                "--eval_batch_size",
                "2048",
                "--onnx_export_selection",
                "best",
                "--onnx_opset",
                "13",
                "--onnx_batch_size",
                "1"
                // 需要开关型参数时，按需取消下面这些注释：
                // ,"--eval_after_train"
                // ,"--plot_after_eval"
                // ,"--export_onnx_after_train"
                // ,"--onnx_dynamic_batch"
                // ,"--onnx_validate"
                // ,"--plan_only"
                // ,"--onnx_output_dir", "./custom_onnx_dir"
            ]
        },
        {
            "name": "Python: evaluate_models_refactored.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Model_AIIC_refactor/evaluate_models_refactored.py",
            "cwd": "${workspaceFolder}/Model_AIIC_refactor",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--exp_dir",
                "./experiments_refactored/20260409_033734_default_6port_separator1",
                "--runs",
                "separator1_grid_search_6ports_hd128_stages2_depth3_share0",
                "--snr_range",
                "30:-3:0",
                "--tdl",
                "A-30,B-100,C-300",
                "--num_batches",
                "100",
                "--batch_size",
                "2048",
                "--device",
                "auto"
                // 默认评估后会自动出图；如需关闭可加：
                // ,"--no-plot_after_eval"
                // ,"--run_dir", "./experiments_refactored/.../your_run_name"
                // ,"--run_dirs", "./run_a,./run_b"
                // ,"--batches_per_snr", "50"
                // ,"--output", "./evaluations/custom_eval"
                // ,"--no-amp"
                // ,"--no-compile"
                // ,"--list_runs"
            ]
        }
    ]
}
