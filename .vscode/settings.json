{
    "iis.configDir": "",
    "github.copilot.enable": {
        "*": false,
        "python": true,
        "javascript": false
    },
    // "github.copilot.advanced": {
    //     "context.maxChars": 2000,  // 限制分析字符数
    //     "context.exclude": ["**/node_modules/**", "**/dist/**"]
    // },
    "github.copilot.asyncDelay": 500,  // 延迟 500 毫秒响应
    "github.copilot.enableAsync": true,
    "files.autoSave": "off",
    "workbench.editor.enablePreview": false,
    "editor.largeFileOptimizations": true,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/.hg/store/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/__pycache__": true
    },
    "editor.renderWhitespace": "none",
    "editor.cursorBlinking": "smooth",
    "editor.experimental.asyncTokenization": true,
    "editor.hardwareAcceleration": "off",
    "github.copilot.useGPU": false  // 强制使用 CPU 计算
}